{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ], // Files to include in the project
  "exclude": [
    "node_modules"
  ] // Folders to ignore
}